function doGet(e) {
  try {
    var searchQuery = (e.parameter.q || "").toLowerCase().trim();

    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheets()[0];
    var data = sheet.getDataRange().getValues();

    if (data.length === 0) {
      return output({ success: false, message: "Sheet is empty" });
    }

    var headers = data[0];
    var results = [];

    for (var i = 1; i < data.length; i++) {
      var row = data[i];
      var matchFound = false;

      // search logic
      if (!searchQuery) {
        matchFound = true; // no query → show all
      } else {
        for (var j = 0; j < row.length; j++) {
          if (row[j] &&
              row[j].toString().toLowerCase().includes(searchQuery)) {
            matchFound = true;
            break;
          }
        }
      }

      if (matchFound) {
        var rowData = {};
        headers.forEach(function(header, index) {
          rowData[header] = row[index];
        });
        results.push(rowData);
      }
    }

    return output({
      success: true,
      total: results.length,
      cards: results
    });

  } catch (err) {
    return output({
      success: false,
      error: err.toString()
    });
  }
}

// helper function
function output(data) {
  return ContentService
    .createTextOutput(JSON.stringify(data))
    .setMimeType(ContentService.MimeType.JSON);
}
